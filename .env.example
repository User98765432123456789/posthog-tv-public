# Copy this file to .env for local development.
# DO NOT COMMIT the real .env - it is ignored via .gitignore.
# In GitHub Actions, POSTHOG_DASHBOARD_URL comes from a repository Secret.

# Public share URL from PostHog (Dashboard -> Share -> Public access).
# Treat this URL as a secret: anyone with the token can view the dashboard.
POSTHOG_DASHBOARD_URL=https://eu.posthog.com/shared/your_share_token_here

# Optional: how long to wait for charts to fully render before screenshot.
# Default: 15000 ms. Increase if you see partially-loaded charts in the output.
RENDER_WAIT_MS=15000
